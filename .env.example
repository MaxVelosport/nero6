# ============================================================
#  НейроЗачёт — переменные окружения
#  Скопируй в .env, заполни значения, никогда не коммить .env
# ============================================================

# ── Основное ────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
# Публичный URL без слэша в конце
APP_URL=https://neurozachet.ru
APP_NAME=НейроЗачёт

# ── Supabase (БД) ────────────────────────────────────────────
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_KEY=eyJhbGci...
# Supabase Dashboard → Settings → Database → Connection string → URI
SUPABASE_DATABASE_URL=postgresql://postgres:PASSWORD@db.XXXXXXXX.supabase.co:5432/postgres

# ── AI провайдеры ────────────────────────────────────────────
# platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-...
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
# platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-...
# openrouter.ai → Keys  (Gemini 2.0 Flash, Gemini 2.5 Pro)
OPENROUTER_API_KEY=sk-or-v1-...
# console.x.ai → API Keys  (Grok 3)
XAI_API_KEY=xai-...

# ── Email (SMTP) ─────────────────────────────────────────────
# Beget → Почта → Домены → neurozachet.ru
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_INFO_USER=info@neurozachet.ru
# Beget → Почта → ящик info@neurozachet.ru → Изменить → Пароль
SMTP_INFO_PASS=
SMTP_SUPPORT_USER=support@neurozachet.ru
# Beget → Почта → ящик support@neurozachet.ru → Изменить → Пароль
SMTP_SUPPORT_PASS=
EMAIL_FROM=info@neurozachet.ru
SUPPORT_EMAIL=support@neurozachet.ru

# ── Платежи (ЮKassa) ─────────────────────────────────────────
# yookassa.ru → Мой магазин → Настройки → Ключи API
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── Мониторинг (опционально) ──────────────────────────────────
# sentry.io → Projects → [проект] → Settings → SDK Setup → DSN
SENTRY_DSN=

# ── Бэкапы (опционально) ──────────────────────────────────────
# disk.yandex.ru → Настройки → Приложения → Яндекс Диск API
YANDEX_DISK_TOKEN=

# ── Прокси (если хостинг блокирует api.anthropic.com) ─────────
# Например: http://user:pass@proxy.example.com:8080
HTTPS_PROXY=
