# ============================================================
#  SOLVEHUB (НейроЗачёт) — переменные окружения
#  В Replit: добавляй через вкладку "Secrets" (не в .env-файл).
#  Для локального запуска: скопируй в .env и заполни значения.
# ============================================================

# --- Приложение -----------------------------------------------------------
# Публичный URL сайта (без слэша в конце).
# Если не задан — автоматически определяется по домену Replit.
# Примеры: https://neyrozachet.ru  |  https://yourapp.replit.app
APP_URL=

# Название приложения (используется в письмах и заголовках API)
APP_NAME=НейроЗачёт

# --- Email ----------------------------------------------------------------
# Resend API ключ: https://resend.com → API Keys
RESEND_API_KEY=re_...

# Адрес отправителя (домен должен быть подтверждён в Resend).
# Если не задан: НейроЗачёт <noreply@neyrozachet.ru>
EMAIL_FROM=

# Email поддержки (отображается на сайте и в письмах)
SUPPORT_EMAIL=support@neyrozachet.ru

# --- Supabase (база данных) -----------------------------------------------
# Supabase Dashboard → Settings → API
# Project URL:
SUPABASE_URL=https://XXXXXXXX.supabase.co
# anon/public key:
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# service_role key (ВНИМАНИЕ: держи в секрете — обходит Row Level Security):
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- AI провайдеры --------------------------------------------------------
# OpenAI (GPT-4o): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Anthropic (Claude): https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-...

# OpenRouter (Gemini и другие): https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
